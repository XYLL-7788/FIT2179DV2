{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 330,
  "title": {
    "text": "Where do domestic travellers spend the most?",
    "subtitle": "Regional expenditure by state and territory, December Quarter 2025"
  },
  "data": {
    "url": "domestic_tourism_state.csv"
  },
  "transform": [
    {
      "calculate": "datum.state == 'NSW' || datum.state == 'QLD' || datum.state == 'VIC' ? 'Top 3 spending destinations' : 'Other states'",
      "as": "spend_group"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "y": {
          "field": "state_full",
          "type": "nominal",
          "sort": [
            "New South Wales",
            "Queensland",
            "Victoria",
            "Western Australia",
            "South Australia",
            "Tasmania",
            "Australian Capital Territory",
            "Northern Territory"
          ],
          "title": null
        },
        "x": {
          "field": "regional_expenditure_m",
          "type": "quantitative",
          "title": "Regional expenditure ($ million)"
        },
        "color": {
          "field": "spend_group",
          "type": "nominal",
          "scale": {
            "domain": ["Top 3 spending destinations", "Other states"],
            "range": ["#E69F00", "#9FB3C8"]
          },
          "legend": {
            "title": null,
            "orient": "top"
          }
        },
        "tooltip": [
          {
            "field": "state_full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "regional_expenditure_m",
            "type": "quantitative",
            "title": "Expenditure ($m)",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 11
      },
      "encoding": {
        "y": {
          "field": "state_full",
          "type": "nominal",
          "sort": [
            "New South Wales",
            "Queensland",
            "Victoria",
            "Western Australia",
            "South Australia",
            "Tasmania",
            "Australian Capital Territory",
            "Northern Territory"
          ]
        },
        "x": {
          "field": "regional_expenditure_m",
          "type": "quantitative"
        },
        "text": {
          "field": "regional_expenditure_m",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    }
  ]
}
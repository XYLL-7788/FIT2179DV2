{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 420,
  "title": {
    "text": "Four types of domestic tourism destinations",
    "subtitle": "States are grouped by trip volume and tourism value"
  },
  "data": {
    "url": "domestic_tourism_state.csv"
  },
  "transform": [
    {
      "calculate": "datum.volume_group == 'High volume' ? 1 : 0",
      "as": "volume_score"
    },
    {
      "calculate": "datum.value_group == 'High value' ? 1 : 0",
      "as": "value_score"
    },
    {
      "calculate": "datum.state == 'NSW' ? 0.88 : datum.state == 'VIC' ? 1.12 : datum.state == 'QLD' ? 1.00 : datum.state == 'SA' ? 0.12 : datum.state == 'WA' ? -0.12 : datum.state == 'TAS' ? 0.12 : datum.state == 'NT' ? 0.00 : 0.22",
      "as": "x_pos"
    },
    {
      "calculate": "datum.state == 'NSW' ? 0.08 : datum.state == 'VIC' ? -0.08 : datum.state == 'QLD' ? 1.00 : datum.state == 'SA' ? -0.08 : datum.state == 'WA' ? 1.12 : datum.state == 'TAS' ? 0.95 : datum.state == 'NT' ? 0.78 : 0.12",
      "as": "y_pos"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "opacity": 0.08
      },
      "data": {
        "values": [
          {"x": 0, "y": 0, "label": "Lower volume + lower value"},
          {"x": 1, "y": 0, "label": "High volume + lower value"},
          {"x": 0, "y": 1, "label": "Lower volume + high value"},
          {"x": 1, "y": 1, "label": "High volume + high value"}
        ]
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative",
          "scale": {"domain": [-0.45, 1.45]},
          "axis": {
            "values": [0, 1],
            "labelExpr": "datum.value == 0 ? 'Lower volume' : 'High volume'",
            "title": "Trip volume"
          }
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": {"domain": [-0.35, 1.35]},
          "axis": {
            "values": [0, 1],
            "labelExpr": "datum.value == 0 ? 'Lower value' : 'High value'",
            "title": "Tourism value"
          }
        },
        "color": {
          "field": "label",
          "type": "nominal",
          "scale": {
            "range": ["#B8B8B8", "#9FB3C8", "#0B3C5D", "#E69F00"]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#999",
        "strokeDash": [6, 4]
      },
      "encoding": {
        "x": {"datum": 0.5}
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#999",
        "strokeDash": [6, 4]
      },
      "encoding": {
        "y": {"datum": 0.5}
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 1200,
        "opacity": 0.9,
        "stroke": "white",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "x_pos",
          "type": "quantitative",
          "scale": {"domain": [-0.45, 1.45]},
          "axis": {
            "values": [0, 1],
            "labelExpr": "datum.value == 0 ? 'Lower volume' : 'High volume'",
            "title": "Trip volume"
          }
        },
        "y": {
          "field": "y_pos",
          "type": "quantitative",
          "scale": {"domain": [-0.35, 1.35]},
          "axis": {
            "values": [0, 1],
            "labelExpr": "datum.value == 0 ? 'Lower value' : 'High value'",
            "title": "Tourism value"
          }
        },
        "color": {
          "field": "tourism_type",
          "type": "nominal",
          "title": "Tourism type",
          "scale": {
            "domain": [
              "High volume + high value",
              "High volume + lower value",
              "Lower volume + high value",
              "Lower volume + lower value"
            ],
            "range": ["#E69F00", "#9FB3C8", "#0B3C5D", "#B8B8B8"]
          }
        },
        "tooltip": [
          {
            "field": "state_full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "tourism_type",
            "type": "nominal",
            "title": "Tourism type"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "white"
      },
      "encoding": {
        "x": {"field": "x_pos", "type": "quantitative"},
        "y": {"field": "y_pos", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ]
}
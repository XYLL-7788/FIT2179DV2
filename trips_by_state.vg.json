{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 350,
  "title": {
    "text": "Which states received the most overnight trips?",
    "subtitle": "Domestic overnight trips by state and territory, December Quarter 2025"
  },
  "data": {
    "url": "domestic_tourism_state.csv"
  },
  "transform": [
    {
      "calculate": "datum.state == 'NSW' || datum.state == 'VIC' || datum.state == 'QLD' ? 'Top 3 trip destinations' : 'Other states'",
      "as": "trip_group"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": ["NSW", "VIC", "QLD", "WA", "SA", "TAS", "ACT", "NT"],
          "title": "State or territory"
        },
        "y": {
          "field": "overnight_trips_000",
          "type": "quantitative",
          "title": "Overnight trips ('000)"
        },
        "color": {
          "field": "trip_group",
          "type": "nominal",
          "scale": {
            "domain": ["Top 3 trip destinations", "Other states"],
            "range": ["#E69F00", "#9FB3C8"]
          },
          "legend": {
            "title": null,
            "orient": "top"
          }
        },
        "tooltip": [
          {
            "field": "state_full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "overnight_trips_000",
            "type": "quantitative",
            "title": "Overnight trips ('000)",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -6,
        "fontSize": 11
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": ["NSW", "VIC", "QLD", "WA", "SA", "TAS", "ACT", "NT"]
        },
        "y": {
          "field": "overnight_trips_000",
          "type": "quantitative"
        },
        "text": {
          "field": "overnight_trips_000",
          "type": "quantitative",
          "format": ",.0f"
        }
      }
    }
  ]
}
    {
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 330,
  "title": {
    "text": "Which destinations generate more spending per visitor night?",
    "subtitle": "Regional expenditure per visitor night, December Quarter 2025"
  },
  "data": {
    "url": "domestic_tourism_state.csv"
  },
  "transform": [
    {
      "calculate": "datum.spend_per_night_rank <= 3 ? 'Top 3 per-night value' : 'Other states'",
      "as": "night_value_group"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "y": {
          "field": "state_full",
          "type": "nominal",
          "sort": [
            "Northern Territory",
            "Australian Capital Territory",
            "Western Australia",
            "Tasmania",
            "Queensland",
            "South Australia",
            "Victoria",
            "New South Wales"
          ],
          "title": null
        },
        "x": {
          "field": "spend_per_night_aud",
          "type": "quantitative",
          "title": "Spending per visitor night (AUD)"
        },
        "color": {
          "field": "night_value_group",
          "type": "nominal",
          "scale": {
            "domain": ["Top 3 per-night value", "Other states"],
            "range": ["#E69F00", "#9FB3C8"]
          },
          "legend": {
            "title": null,
            "orient": "top"
          }
        },
        "tooltip": [
          {
            "field": "state_full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "spend_per_night_aud",
            "type": "quantitative",
            "title": "Spend per visitor night",
            "format": "$,.0f"
          },
          {
            "field": "spend_per_night_rank",
            "type": "quantitative",
            "title": "Rank"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 11
      },
      "encoding": {
        "y": {
          "field": "state_full",
          "type": "nominal",
          "sort": [
            "Northern Territory",
            "Australian Capital Territory",
            "Western Australia",
            "Tasmania",
            "Queensland",
            "South Australia",
            "Victoria",
            "New South Wales"
          ]
        },
        "x": {
          "field": "spend_per_night_aud",
          "type": "quantitative"
        },
        "text": {
          "field": "spend_per_night_aud",
          "type": "quantitative",
          "format": "$,.0f"
        }
      }
    }
  ]
}